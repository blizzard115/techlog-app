<div class="space-y-6 w-3/4 max-w-lg mx-auto">
  <label class="block text-xl font-bold text-gray-700">学習・エラーログ詳細</label>
  <div class="items-center justify-center">
    <div tabindex="0" aria-label="card 1" class="focus:outline-none mb-7 bg-white p-6 shadow rounded">
      <div class="flex items-center border-b border-gray-200 pb-6">
        <div class="flex items-start justify-between w-full">
          <div class="pl-3">
            <h3 class="focus:outline-none text-lg font-medium leading-5 text-gray-800">
              <%= @post.title %>
            </h3>

            <p class="focus:outline-none text-sm leading-normal pt-2 text-gray-500">
              by <%= link_to @post.user.nickname, user_path(@post.user), class: "hover:text-indigo-600 hover:font-bold" %>
            </p>

            <div class="flex gap-2 pt-3">
              <span class="inline-block text-xs font-medium px-3 py-1 rounded-full <%= @post.post_type == "study_log" ? "bg-blue-100 text-blue-700" : "bg-purple-100 text-purple-700" %>">
                <%= @post.post_type == "study_log" ? "学習記録" : "エラーログ" %>
              </span>

              <span class="inline-block text-xs font-medium px-3 py-1 rounded-full <%= @post.status == "solved" ? "bg-green-100 text-green-700" : "bg-red-100 text-red-700" %>">
                <%= @post.status == "solved" ? "解決済み" : "未解決" %>
              </span>

              <span class="inline-block text-xs font-medium px-3 py-1 rounded-full <%= @post.is_public ? "bg-green-100 text-green-700" : "bg-gray-100 text-gray-700" %>">
                <%= @post.is_public ? "公開" : "非公開" %>
              </span>
            </div>
          </div>

          <% if user_signed_in? && @post.user == current_user %>
            <%= button_to "削除", post_path(@post), method: :delete, class: "text-sm bg-transparent hover:bg-blue-500 text-blue-700 hover:text-white py-1 px-3 border border-blue-500 hover:border-transparent rounded hover:cursor-pointer" %>
          <% end %>
        </div>
      </div>

      <div class="px-2">
        <p class="focus:outline-none text-sm leading-5 py-4 text-gray-600">
          <%= @post.content %>
        </p>
      </div>
    </div>
  </div>
</div>