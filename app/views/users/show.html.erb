<div class="space-y-6 w-3/4 max-w-lg mx-auto">
  <h2 class="text-xl font-bold text-gray-900">
    <%= @user.nickname %>さんの学習・エラーログ一覧
  </h2>
  <p class="text-gray-600">全投稿数: <%= @post_count %>件</p>

  <% if @posts.empty? %>
    <div class="bg-white rounded-lg shadow-sm p-6 text-center">
      <p class="text-gray-600">まだ投稿がありません。</p>
    </div>
  <% else %>
    <div class="space-y-6">
      <% @posts.each do |post| %>
        <div class="focus:outline-none mb-7 bg-white p-6 shadow rounded">
          <div class="flex items-center border-b border-gray-200 pb-6">
            <div class="flex items-start justify-between w-full">
              <div class="pl-3">
                <p class="text-lg font-medium leading-5 text-gray-800">
                  <%= link_to post.title, post_path(post), class: "hover:text-indigo-600" %>
                </p>

                <p class="text-sm leading-normal pt-2 text-gray-500">
                  <%= post.created_at.strftime("%Y年%m月%d日") %>
                </p>

                <div class="flex gap-2 pt-3">
                  <span class="inline-block text-xs font-medium px-3 py-1 rounded-full <%= post.post_type == "study_log" ? "bg-blue-100 text-blue-700" : "bg-purple-100 text-purple-700" %>">
                    <%= post.post_type == "study_log" ? "学習記録" : "エラーログ" %>
                  </span>

                  <span class="inline-block text-xs font-medium px-3 py-1 rounded-full <%= post.status == "solved" ? "bg-green-100 text-green-700" : "bg-red-100 text-red-700" %>">
                    <%= post.status == "solved" ? "解決済み" : "未解決" %>
                  </span>
                </div>
              </div>
            </div>
          </div>

          <div class="px-2">
            <p class="text-sm leading-5 py-4 text-gray-600 line-clamp-3 overflow-hidden">
              <%= post.content %>
            </p>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>